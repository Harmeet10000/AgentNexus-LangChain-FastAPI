{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ".opencode/plugins/graphify.js",
   "@warp-dot-dev/opencode-warp",
    "@mohak34/opencode-notifier@latest",
        "@zenobius/opencode-skillful",
        "opencode-scheduler",
        "opencode-firecrawl",
        "opencode-conductor-plugin",
    "oac"
  ],
  "skills": {
    "paths": [
      ".opencode/skills",
        "/home/harmeet/Desktop/prompts/skills"
    ]
  },
  "compaction": {
    "auto": true
  },
  "permission": {
    "bash": {
      "*": "ask",
      "uv *": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "ty *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "graphify *": "allow",
      "rm -rf *": "ask",
      "git reset --hard *": "deny"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "skill": "allow",
    "webfetch": "allow"
  }
}
